# =========================
# Core (required)
# =========================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-secret

# =========================
# Database (required)
# - PostgreSQL adalah database utama.
# - Default memakai PostgreSQL system service lokal pada port 5432.
# - Jika memakai Docker fallback, jalankan `npm run db:up:docker`
#   lalu sesuaikan port ke 5433 atau override POSTGRES_PORT=5432.
# - E2E default mengikuti DATABASE_URL jika tidak diisi
# =========================
DATABASE_URL=postgresql://sis:sis@127.0.0.1:5432/sis?schema=public
E2E_DATABASE_URL=postgresql://sis:sis@127.0.0.1:5433/sis?schema=public

# =========================
# Storage S3 / MinIO (required untuk upload/asset)
# =========================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sis-uploads

# =========================
# Notifications (optional)
# =========================
WA_PROVIDER=dummy
OUTBOX_MAX_ATTEMPTS=5
CRON_SECRET=replace-with-cron-secret
WEBHOOK_SECRET=replace-with-webhook-secret

# SMTP (opsional; jika kosong fallback ke dummy email sender)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@sis.local

# =========================
# HR rules (optional)
# =========================
HR_TOLERANCE_MINUTES=10
HR_CORE_START=07:00
HR_CORE_END=15:00

# =========================
# Misc (optional)
# =========================
QR_PROVIDER_URL=https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=
SEED_ADMIN_EMAIL=admin@sis.local
SEED_ADMIN_PASSWORD=admin123

# =========================
# Dapodik Integration (optional)
# - Untuk demo antrian sync: set ENABLED=true dan MODE=mock
# =========================
DAPODIK_SYNC_ENABLED=false
DAPODIK_SYNC_MODE=disabled
DAPODIK_SYNC_MAX_ATTEMPTS=5
DAPODIK_BASE_URL=
DAPODIK_CLIENT_ID=
DAPODIK_CLIENT_SECRET=

# Mapping ledger otomatis untuk pembayaran/refund invoice -> keuangan operasional
FINANCE_INVOICE_INCOME_ACCOUNT_CODE=4100
FINANCE_INVOICE_INCOME_ACCOUNT_NAME=Pendapatan Pembayaran Tagihan
FINANCE_INVOICE_REFUND_ACCOUNT_CODE=5100
FINANCE_INVOICE_REFUND_ACCOUNT_NAME=Biaya Refund Pembayaran
FINANCE_INVOICE_CASH_ACCOUNT_CODE=CASH-OPS
FINANCE_INVOICE_CASH_ACCOUNT_NAME=Kas Operasional
FINANCE_INVOICE_BANK_ACCOUNT_CODE=BANK-OPS
FINANCE_INVOICE_BANK_ACCOUNT_NAME=Bank Operasional

# =========================
# Docker Compose override (optional)
# dipakai jika menjalankan stack docker-compose.yml
# =========================
POSTGRES_DB=sis
POSTGRES_USER=sis
POSTGRES_PASSWORD=sis
POSTGRES_PORT=5433

# Legacy MariaDB compatibility only. Tidak dipakai sebagai database utama.
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=sis
MARIADB_USER=sis
MARIADB_PASSWORD=sis
MARIADB_PORT=3306
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
