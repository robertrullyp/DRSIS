  @@index([galleryId, itemOrder], map: "cms_gallery_item_gallery_itemOrder_idx")
  @@index([mediaId], map: "cms_gallery_item_mediaId_idx")
  @@map("cms_gallery_item")
}

model CmsContactMessage {
